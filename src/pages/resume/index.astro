---
import { Icon } from "astro-icon/components";
import { cvContent } from "../../i18n/sections/cv";
import CvLayout from "../../layouts/CvLayout.astro";

const cv = cvContent["zh-TW"];
---

<CvLayout title="黃宥睿 — 履歷" description={cv.summary} lang="zh-TW">
	<div class="toolbar">
		<a class="tb-home" href="/">← osga.dev</a>
		<a class="download-btn" href="/cv.pdf" download>
			<Icon name="lucide:download" aria-hidden="true" />
			<span>下載 PDF</span>
		</a>
	</div>

	<article class="cv">
		<header class="cv-head">
			<div class="cv-name-row">
				<h1 class="cv-name">{cv.name}</h1>
				<span class="cv-name-alt">{cv.nameAlt}</span>
			</div>
			<p class="cv-headline">{cv.headline}</p>
			<div class="cv-contacts">
				<span><Icon name="lucide:map-pin" aria-hidden="true" />{cv.location}</span>
				{cv.contacts.map((c) => (
					<a href={c.href} target="_blank" rel="noreferrer">
						<Icon name={c.icon} aria-hidden="true" />{c.label}
					</a>
				))}
			</div>
		</header>

		<section>
			<h2>{cv.sectionLabels.summary}</h2>
			<p class="cv-summary">{cv.summary}</p>
		</section>

		<section>
			<h2>{cv.sectionLabels.education}</h2>
			{cv.education.map((e) => (
				<div class="entry">
					<div class="entry-head">
						<span class="entry-org">{e.org}</span>
						<span class="entry-period">{e.period}</span>
					</div>
					<div class="entry-detail">{e.detail}</div>
				</div>
			))}
		</section>

		<section>
			<h2>{cv.sectionLabels.experience}</h2>
			{cv.experience.map((e) => (
				<div class="entry">
					<div class="entry-head">
						<span class="entry-org">{e.org}</span>
						<span class="entry-period">{e.period}</span>
					</div>
					<div class="entry-role">{e.role}</div>
					<ul class="bullets">
						{e.bullets.map((b) => (
							<li>{b}</li>
						))}
					</ul>
				</div>
			))}
		</section>

		<section>
			<h2>{cv.sectionLabels.projects}</h2>
			<ul class="bullets">
				{cv.projects.map((p) => (
					<li>
						{p.href ? (
							<a class="proj-name" href={p.href} target="_blank" rel="noreferrer">{p.name}</a>
						) : (
							<span class="proj-name">{p.name}</span>
						)}
						<span class="dash"> — </span>
						<span>{p.desc}</span>
					</li>
				))}
			</ul>
		</section>

		<section>
			<h2>{cv.sectionLabels.achievements}</h2>
			<ul class="bullets">
				{cv.achievements.map((g) => (
					<li>
						<span class="ach-year">{g.year}</span>
						<span>{g.items.join(" · ")}</span>
					</li>
				))}
			</ul>
		</section>

		<section>
			<h2>{cv.sectionLabels.community}</h2>
			<ul class="bullets">
				{cv.community.map((c) => (
					<li>{c}</li>
				))}
			</ul>
		</section>

		<section>
			<h2>{cv.sectionLabels.skills}</h2>
			<div class="cv-skills">
				{cv.skills.map((s) => (
					<>
						<span class="skill-label">{s.label}</span>
						<span class="skill-value">{s.value}</span>
					</>
				))}
				<span class="skill-label">{cv.sectionLabels.certifications}</span>
				<span class="skill-value">{cv.certifications}</span>
			</div>
		</section>
	</article>
</CvLayout>

<style>
	/* ---- toolbar (screen only; removed in print) ---- */
	.toolbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		width: 100%;
		max-width: 210mm;
		margin: 0 auto 1rem;
	}

	.tb-home {
		font-family: var(--mono);
		color: var(--muted);
		text-decoration: none;
		font-size: 0.8rem;
	}

	.tb-home:hover {
		color: var(--accent);
	}

	.download-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		border: 1px solid var(--accent);
		background: var(--accent);
		color: #fff;
		border-radius: 4px;
		padding: 0.4rem 0.85rem;
		font-family: var(--mono);
		font-size: 0.78rem;
		line-height: 1;
		text-decoration: none;
		cursor: pointer;
	}

	.download-btn:hover {
		background: #15241d;
	}

	.download-btn :global(svg) {
		width: 0.95em;
		height: 0.95em;
	}

	/*
	 * Single flowing document — no transforms, fixed heights, or overflow
	 * clipping — so screen and print render identically (page margins via @page).
	 */
	.cv {
		width: 100%;
		max-width: 210mm;
		margin: 0 auto;
		padding: 11mm 13mm;
		background: var(--paper);
		color: var(--ink);
		font-size: 10.8px;
		line-height: 1.5;
		-webkit-print-color-adjust: exact;
		print-color-adjust: exact;
	}

	/* ---- header ---- */
	.cv-head {
		padding-bottom: 0.75em;
		border-bottom: 2px solid var(--accent);
	}

	.cv-name-row {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 0.6em 1em;
		flex-wrap: wrap;
	}

	.cv-name {
		margin: 0;
		font-size: 2.15em;
		font-weight: 700;
		letter-spacing: 0.06em;
		line-height: 1.1;
	}

	.cv-name-alt {
		font-family: var(--mono);
		font-size: 0.9em;
		font-weight: 500;
		color: var(--accent-soft);
	}

	.cv-headline {
		margin: 0.55em 0 0;
		font-size: 0.95em;
		font-weight: 600;
		letter-spacing: 0.03em;
		color: var(--accent);
	}

	.cv-contacts {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.3em 1.1em;
		margin-top: 0.65em;
		font-family: var(--mono);
		font-size: 0.82em;
		color: var(--muted);
	}

	.cv-contacts a,
	.cv-contacts span {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		color: var(--muted);
		text-decoration: none;
	}

	.cv-contacts a:hover {
		color: var(--accent);
	}

	.cv-contacts :global(svg) {
		width: 1.1em;
		height: 1.1em;
		color: var(--accent);
		flex-shrink: 0;
	}

	/* ---- section heading:  ◆ TITLE ───────────── ---- */
	.cv h2 {
		display: flex;
		align-items: center;
		gap: 0.6em;
		margin: 1.15em 0 0.5em;
		font-size: 0.92em;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent);
	}

	.cv h2::before {
		content: "";
		flex: none;
		width: 0.5em;
		height: 0.5em;
		background: var(--accent);
		transform: rotate(45deg);
	}

	.cv h2::after {
		content: "";
		flex: 1;
		height: 1px;
		background: var(--rule);
	}

	.cv section:first-of-type h2 {
		margin-top: 0.6em;
	}

	.cv-summary {
		margin: 0;
	}

	/* ---- entries ---- */
	.entry {
		margin: 0 0 0.55em;
	}

	.entry:last-child {
		margin-bottom: 0;
	}

	.entry-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1em;
	}

	.entry-org {
		font-weight: 700;
	}

	.entry-period {
		font-family: var(--mono);
		color: var(--muted);
		font-size: 0.8em;
		white-space: nowrap;
	}

	.entry-role {
		color: var(--accent);
		font-weight: 600;
		font-size: 0.92em;
		margin-top: 0.1em;
	}

	.entry-detail {
		font-size: 0.95em;
		margin-top: 0.1em;
	}

	/* ---- diamond bullets (shared) ---- */
	.bullets {
		margin: 0.25em 0 0;
		padding: 0;
		list-style: none;
		font-size: 0.95em;
	}

	.entry .bullets {
		margin-top: 0.18em;
	}

	.bullets li {
		position: relative;
		padding-left: 1.1em;
		margin-bottom: 0.28em;
	}

	.bullets li:last-child {
		margin-bottom: 0;
	}

	.bullets li::before {
		content: "";
		position: absolute;
		left: 0.1em;
		top: 0.5em;
		width: 0.34em;
		height: 0.34em;
		background: var(--accent-soft);
		transform: rotate(45deg);
	}

	.proj-name {
		font-weight: 700;
		color: var(--accent);
		text-decoration: none;
	}

	.proj-name:hover {
		text-decoration: underline;
	}

	.dash {
		color: var(--muted);
	}

	.ach-year {
		font-family: var(--mono);
		font-weight: 700;
		color: var(--accent);
		margin-right: 0.5em;
	}

	/* ---- skills ---- */
	.cv-skills {
		display: grid;
		grid-template-columns: max-content 1fr;
		gap: 0.32em 1em;
	}

	.skill-label {
		font-weight: 700;
		color: var(--accent);
	}

	/* slightly larger / tighter padding when browsing on a phone (screen only) */
	@media screen and (max-width: 560px) {
		.cv {
			padding: 1.4rem 1.15rem 2rem;
			font-size: 12px;
		}
	}

	@media print {
		.toolbar {
			display: none !important;
		}

		.cv {
			max-width: none;
			padding: 0;
		}
	}
</style>
