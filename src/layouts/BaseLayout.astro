---
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/700.css";
import "../styles/global.css";

type Props = {
	title: string;
	description: string;
	lang?: string;
};

const { title, description, lang = "en" } = Astro.props;
---

<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
		<script is:inline>
			try {
				const savedTheme = window.localStorage.getItem("theme-preference");
				const systemTheme = window.matchMedia("(prefers-color-scheme: dark)").matches
					? "dark"
					: "light";
				document.documentElement.dataset.theme = savedTheme ?? systemTheme;
			} catch {
				document.documentElement.dataset.theme = "light";
			}
		</script>
		<style>
			:root,
			:root[data-theme="light"] {
				color-scheme: light;
				--accent: #495954;
				--bg: #f7f1e3;
				--text: #151515;
				--muted: #666b67;
				--icon: #7a837f;
				--icon-hover: #495954;
				--line: rgba(73, 89, 84, 0.22);
				--ease: cubic-bezier(0.2, 0.65, 0.3, 0.9);
				--theme-duration: 0.32s;
			}

			:root[data-theme="dark"] {
				color-scheme: dark;
				--bg: #151515;
				--text: #f7f1e3;
				--muted: #a59f93;
				--icon: #8f978f;
				--icon-hover: #c7d1cc;
				--line: rgba(199, 209, 204, 0.18);
			}

			* {
				box-sizing: border-box;
			}

			html,
			body {
				margin: 0;
				min-height: 100%;
			}

			body {
				font-family: "JetBrains Mono", monospace;
				background: var(--bg);
				color: var(--text);
				transition:
					background-color var(--theme-duration) var(--ease),
					color var(--theme-duration) var(--ease);
			}

			main {
				display: flex;
				width: 100%;
				min-height: 100vh;
				overflow: hidden;
			}

			.page-shell {
				display: flex;
				flex: 1;
				background: transparent;
			}

			.page-stage {
				flex: 1;
				display: flex;
				justify-content: center;
				padding: 15vh 1.5rem;
				overflow-y: auto;
			}

			.page-stack {
				position: relative;
				display: flex;
				flex-direction: column;
				align-items: flex-start;
				width: 100%;
				max-width: 40rem;
				gap: 5rem;
				transition: transform 0.6s var(--ease);
			}

			:global(.wordmark) {
				margin: 0;
				font-weight: 700;
				font-size: clamp(1.13rem, 13.13vw, 3.75rem);
				line-height: 1;
				white-space: nowrap;
				letter-spacing: -0.06em;
				will-change: font-size;
				transition: color var(--theme-duration) var(--ease);
			}

			:global(.wordmark-spacer) {
				overflow: hidden;
				transition: height 0.35s var(--ease);
			}

			:global(.reveal-content) {
				transition:
					opacity 0.45s var(--ease),
					transform 0.45s var(--ease),
					filter 0.45s var(--ease);
			}

			:global(body:not(.is-expanded) .wordmark-spacer) {
				height: 0;
			}

			:global(body:not(.is-expanded) .reveal-content) {
				opacity: 0;
				transform: translateY(0.5rem);
				filter: blur(4px);
				pointer-events: none;
			}

			:global(body.is-expanded .wordmark-spacer) {
				height: 0.4rem;
			}

			:global(body.is-expanded .reveal-content) {
				opacity: 1;
				transform: translateY(0);
				filter: blur(0);
				pointer-events: auto;
			}

			:global(.lead) {
				margin: 1rem 0 0;
				max-width: none;
				font-size: 1rem;
				line-height: 1.6;
				white-space: pre-line;
				color: var(--muted);
				transition: color var(--theme-duration) var(--ease);
			}

			:root::view-transition-group(root) {
				animation-duration: 560ms;
			}

			:root::view-transition-image-pair(root) {
				isolation: auto;
			}

			:root::view-transition-old(root),
			:root::view-transition-new(root) {
				animation: none;
				mix-blend-mode: normal;
				display: block;
			}

			:global(.tagline),
			:global(.eyebrow),
			:global(.section-title),
			:global(.period),
			:global(.company),
			:global(.experience-body p),
			:global(.experience-card h3),
			:global(.locale-switcher a) {
				transition:
					color var(--theme-duration) var(--ease),
					border-color var(--theme-duration) var(--ease);
			}

			:global(.experience-card) {
				transition: border-color var(--theme-duration) var(--ease);
			}

			@media (max-width: 720px) {
				.page-stage {
					padding: 8vh 1rem 3rem;
				}

				.page-stack {
					gap: 3rem;
				}

				:global(.wordmark) {
					white-space: normal;
					word-break: break-word;
				}

				:global(.lead) {
					font-size: 0.95rem;
				}
			}

			@media (max-width: 520px) {
				.page-stage {
					padding: 6vh 0.9rem 2.5rem;
				}

				.page-stack {
					gap: 2.25rem;
				}

				:global(.tagline) {
					font-size: 0.92rem;
				}

				:global(.lead) {
					margin-top: 0.85rem;
					font-size: 0.92rem;
					line-height: 1.7;
				}
			}

			@media (prefers-reduced-motion: reduce) {
				body,
				.page-stack,
				:global(.wordmark-spacer),
				:global(.reveal-content),
				:global(.wordmark),
				:global(.lead),
				:global(.tagline),
				:global(.eyebrow),
				:global(.section-title),
				:global(.period),
				:global(.company),
				:global(.experience-body p),
				:global(.experience-card h3),
				:global(.experience-card),
				:global(.locale-switcher a) {
					transition: none;
				}
			}
		</style>
	</head>
	<body>
		<main>
			<div class="page-shell">
				<div class="page-stage">
					<div class="page-stack">
						<slot />
					</div>
				</div>
			</div>
		</main>
	</body>
</html>
