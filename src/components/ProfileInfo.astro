---
import type { InfoSection } from "../i18n/content";

type Props = {
	sections: readonly InfoSection[];
};

const { sections } = Astro.props;
---

<div class="profile-info">
	{sections.map((section) => (
		<section class="info-section">
			{section.title && <p class="info-title meta-kicker">{section.title}</p>}
			<ul class="info-list divided-list">
				{section.items.map((item) => {
					const values = Array.isArray(item.value) ? item.value : [item.value];

					return (
						<li class="info-item">
							<span class="info-label">{item.label}</span>
							{item.href ? (
								<a class="info-value" href={item.href}>{values[0]}</a>
							) : values.length === 1 ? (
								<span class="info-value">{values[0]}</span>
							) : (
								<ul class="info-value-list">
									{values.map((value) => (
										<li class="info-value-list-item">{value}</li>
									))}
								</ul>
							)}
						</li>
					);
				})}
			</ul>
		</section>
	))}
</div>

<style>
	.profile-info {
		margin-top: 1.25rem;
		width: 100%;
	}

	.info-section + .info-section {
		margin-top: 1.25rem;
	}

	.info-item {
		display: grid;
		grid-template-columns: minmax(4.75rem, 6rem) 1fr;
		gap: 0.75rem;
		padding: 0.7rem 0;
		border-bottom: 1px solid var(--line);
		align-items: start;
	}

	.info-value {
		color: var(--text);
		text-decoration: none;
		word-break: break-word;
	}

	.info-value-list {
		margin: 0;
		padding-left: 1.1rem;
		color: var(--text);
	}

	.info-value-list-item + .info-value-list-item {
		margin-top: 0.25rem;
	}

	a.info-value:hover {
		color: var(--icon-hover);
	}

	@media (max-width: 520px) {
		.profile-info {
			margin-top: 1rem;
		}

		.info-item {
			grid-template-columns: 1fr;
			gap: 0.28rem;
			font-size: 0.8rem;
			padding: 0.8rem 0;
		}
	}
</style>
