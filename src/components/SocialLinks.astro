---
import { Icon } from "astro-icon/components";
import type { SocialLink } from "../i18n/content";

type Props = {
	links: readonly SocialLink[];
};

const { links } = Astro.props;
---

<div class="socials" aria-label="Social links">
	{links.map((link) => (
		<a href={link.href} target="_blank" rel="noreferrer" aria-label={link.label}>
			<Icon name={link.icon} aria-hidden="true" />
		</a>
	))}
</div>

<style>
	.socials {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-top: 0.25rem;
	}

	.socials a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.75rem;
		height: 1.75rem;
		border-radius: 999px;
		color: var(--icon);
		text-decoration: none;
		transition:
			border-color var(--theme-duration, 0.32s) ease,
			color 0.2s ease,
			transform 0.2s ease;
	}

	.socials a:hover {
		color: var(--icon-hover);
		transform: translateY(-1px);
	}

	.socials :global(svg) {
		width: 1rem;
		height: 1rem;
		display: block;
	}

	@media (prefers-reduced-motion: reduce) {
		.socials a {
			transition: none;
		}
	}
</style>
