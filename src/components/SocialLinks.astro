---
type SocialLink = {
	label: string;
	href: string;
	icon: "github" | "x" | "linkedin";
};

type Props = {
	links: readonly SocialLink[];
};

const { links } = Astro.props;

const icons = {
	github:
		"M12 .5a12 12 0 0 0-3.79 23.39c.6.1.82-.26.82-.58v-2.03c-3.34.73-4.04-1.41-4.04-1.41-.55-1.38-1.33-1.75-1.33-1.75-1.1-.74.08-.72.08-.72 1.2.08 1.84 1.24 1.84 1.24 1.08 1.83 2.82 1.3 3.5 1 .1-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.94 0-1.32.47-2.4 1.24-3.24-.12-.3-.54-1.53.12-3.19 0 0 1.02-.33 3.34 1.24a11.5 11.5 0 0 1 6.08 0c2.32-1.57 3.34-1.24 3.34-1.24.66 1.66.24 2.9.12 3.19.77.84 1.24 1.92 1.24 3.24 0 4.62-2.8 5.64-5.48 5.94.43.37.82 1.1.82 2.22v3.29c0 .32.22.69.82.58A12 12 0 0 0 12 .5Z",
	x: "M18.9 2H22l-6.78 7.75L23.2 22h-6.27l-4.91-7.38L5.56 22H2.44l7.26-8.3L1.98 2h6.43l4.44 6.8L18.9 2Zm-1.1 18h1.73L7.47 3.9H5.61L17.8 20Z",
	linkedin:
		"M4.98 3.5a2.49 2.49 0 1 0 0 4.98 2.49 2.49 0 0 0 0-4.98ZM2.75 9h4.46v12H2.75V9Zm7.01 0h4.27v1.64h.06c.6-1.12 2.06-2.3 4.23-2.3 4.52 0 5.35 2.98 5.35 6.86V21h-4.45v-5.13c0-1.22-.02-2.8-1.7-2.8-1.7 0-1.96 1.33-1.96 2.71V21H9.76V9Z",
};
---

<div class="socials" aria-label="Social links">
	{links.map((link) => (
		<a href={link.href} target="_blank" rel="noreferrer" aria-label={link.label}>
			<svg viewBox="0 0 24 24" aria-hidden="true">
				<path fill="currentColor" d={icons[link.icon]} />
			</svg>
		</a>
	))}
</div>

<style>
	.socials {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-top: 0.25rem;
	}

	.socials a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.75rem;
		height: 1.75rem;
		border-radius: 999px;
		color: var(--icon);
		text-decoration: none;
		transition:
			border-color var(--theme-duration, 0.32s) ease,
			color 0.2s ease,
			transform 0.2s ease;
	}

	.socials a:hover {
		color: var(--icon-hover);
		transform: translateY(-1px);
	}

	.socials svg {
		width: 1rem;
		height: 1rem;
		display: block;
	}

	@media (prefers-reduced-motion: reduce) {
		.socials a {
			transition: none;
		}
	}
</style>
