---
type Props = {
	label: string;
	href: string;
};

const { label, href } = Astro.props;
---

<nav class="locale-switcher reveal-content" aria-label="Language switcher">
	<a class="interactive-link hover-scale" href={href} data-skip-intro>{label}</a>
</nav>

<style>
	.locale-switcher {
		display: flex;
		justify-content: flex-end;
	}

	.locale-switcher a {
		display: inline-block;
		color: var(--muted);
		text-decoration: none;
		font-size: 0.88rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		--hover-scale: 1.08;
	}
</style>
