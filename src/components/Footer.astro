---
import type { QuickLink } from "../i18n/content";

type Props = {
	title: string;
	quickLinks: readonly QuickLink[];
};

const { title, quickLinks } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer reveal-content">
	<p class="footer-meta text-muted">© {year} {title}</p>
	<nav class="footer-links" aria-label="Footer">
		{quickLinks.map((link) => (
			<a class="interactive-link hover-scale" href={link.href}>
				{link.label}
			</a>
		))}
	</nav>
</footer>

<style>
	.site-footer {
		width: 100%;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		padding-top: 1rem;
		border-top: 1px solid var(--line);
	}

	.footer-meta {
		margin: 0;
		font-size: 0.88rem;
	}

	.footer-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.85rem;
	}

	.footer-links a {
		color: var(--muted);
		font-size: 0.88rem;
		text-decoration: none;
	}

	@media (max-width: 520px) {
		.site-footer {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.75rem;
		}

		.footer-links {
			justify-content: flex-start;
		}
	}
</style>
