---
import clawdLight from "../assets/clawdLight.gif";
import clawdDark from "../assets/clawdDark.gif";
import type { QuickLink } from "../i18n/content";

type Props = {
	title: string;
	quickLinks: readonly QuickLink[];
};

const { title, quickLinks } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer reveal-content">
	<div class="footer-image" aria-hidden="true">
		<img class="footer-gif footer-gif-light" src={clawdLight.src} alt="" />
		<img class="footer-gif footer-gif-dark" src={clawdDark.src} alt="" />
	</div>

	<hr class="footer-rule" />

	<div class="footer-content">
		<p class="footer-meta text-muted">© {year} {title}</p>
		<nav class="footer-links" aria-label="Footer">
			{quickLinks.map((link) => (
				<a class="interactive-link hover-scale" href={link.href}>
					{link.label}
				</a>
			))}
		</nav>
	</div>
</footer>

<style>
	.site-footer {
		width: 100%;
		display: flex;
		flex-direction: column;
		align-items: stretch;
		margin-top: -3rem;
	}

	.footer-image {
		position: relative;
		display: flex;
		justify-content: flex-end;
		padding-right: 1rem;
		line-height: 0;
		pointer-events: none;
	}

	.footer-gif {
		display: block;
		width: min(50%, 5rem);
		height: auto;
	}

	.footer-gif-dark {
		position: absolute;
		top: -0.35rem;
		right: 1rem;
		opacity: 0;
	}

	:global(:root[data-theme="dark"] .footer-gif-light) {
		opacity: 0;
	}

	:global(:root[data-theme="dark"] .footer-gif-dark) {
		opacity: 1;
	}

	.footer-rule {
		width: 100%;
		height: 1px;
		margin: 0;
		border: 0;
		background: var(--line);
	}

	.footer-content {
		display: flex;
		width: 100%;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		padding-top: 1rem;
	}

	.footer-meta {
		margin: 0;
		margin-right: auto;
		font-size: 0.88rem;
	}

	.footer-links {
		display: flex;
		margin-left: auto;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.85rem;
	}

	.footer-links a {
		color: var(--muted);
		font-size: 0.88rem;
		text-decoration: none;
	}

	@media (max-width: 520px) {
		.footer-content {
			align-items: center;
		}

		.footer-links {
			justify-content: flex-end;
		}

		.footer-image img {
			width: min(100%, 5.5rem);
		}
	}
</style>
