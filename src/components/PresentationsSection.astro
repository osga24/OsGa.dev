---
import type { PresentationCategory } from "../i18n/content";

type Props = {
	title: string;
	categories: readonly PresentationCategory[];
};

const { title, categories } = Astro.props;
---

<section class="presentations reveal-content" aria-labelledby="presentations-title">
	<div class="presentations-header">
		<h2 id="presentations-title" class="presentations-title">{title}</h2>
	</div>

	<div class="presentations-groups">
		{categories.map((category) => (
			<section class="presentations-group">
				<p class="presentations-label meta-kicker">{category.label}</p>
				<div class="presentations-list divided-list">
					{category.items.map((item) => (
						<article class="presentation-item">
							<div class="presentation-main">
								<p class="presentation-date">{item.date}</p>
								<p class="presentation-content">{item.content}</p>
							</div>
							{item.desc && <p class="presentation-desc">{item.desc}</p>}
							{item.topic && <p class="presentation-team">{item.topic}</p>}
						</article>
					))}
				</div>
			</section>
		))}
	</div>
</section>

<style>
	.presentations {
		width: 100%;
		margin-top: 0.5rem;
	}

	.presentations-header {
		margin-bottom: 1.25rem;
	}

	.presentations-title {
		margin: 0;
		font-size: clamp(1.35rem, 4vw, 1.8rem);
		line-height: 1.1;
	}

	.presentations-group + .presentations-group {
		margin-top: 1.5rem;
	}

	.presentations-label {
		padding-bottom: 0.55rem;
		margin-bottom: 0.2rem;
	}

	.presentations-list {
		margin-top: 0.35rem;
	}

	.presentations-list .presentation-item {
		display: block;
		padding: 0.9rem 0 1rem;
	}

	.presentation-main {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 0.3rem 0.75rem;
	}

	.presentation-content {
		margin: 0;
		flex: 1;
		min-width: min(22rem, 100%);
		white-space: pre-line;
		line-height: 1.7;
	}

	.presentation-desc {
		margin: 0.35rem 0 0;
		color: var(--muted);
		font-size: 0.92rem;
		line-height: 1.6;
	}

	.presentation-team {
		margin: 0.4rem 0 0;
		color: var(--muted);
		font-size: 0.9rem;
		line-height: 1.6;
	}

	.presentation-date {
		margin: 0;
		flex-shrink: 0;
		white-space: nowrap;
		color: var(--muted);
		font-size: 0.92rem;
	}

	@media (max-width: 520px) {
		.presentations {
			margin-top: 0;
		}

		.presentations-header {
			margin-bottom: 1rem;
		}
	}
</style>
