---
import Certifications from "./Certifications.astro";
import CommunityConferenceSection from "./CommunityConferenceSection.astro";
import CompetitionsSection from "./CompetitionsSection.astro";
import ExperienceSection from "./ExperienceSection.astro";
import Footer from "./Footer.astro";
import HeroSection from "./HeroSection.astro";
import LocaleSwitcher from "./LocaleSwitcher.astro";
import PresentationsSection from "./PresentationsSection.astro";
import ThemeToggle from "./ThemeToggle.astro";
import type { SiteContent } from "../i18n/content";

type Props = {
	content: SiteContent;
};

const { content } = Astro.props;
---

<div class="page-actions">
	<ThemeToggle
		lightLabel={content.themeLightLabel}
		darkLabel={content.themeDarkLabel}
	/>
	<LocaleSwitcher
		label={content.switchLocaleLabel}
		href={content.switchLocaleHref}
	/>
</div>

<HeroSection
	title={content.title}
	tagline={content.tagline}
	intro={content.intro}
	socialLinks={content.socialLinks}
	infoSections={content.infoSections}
	quickLinks={content.quickLinks}
/>

<ExperienceSection
	title={content.experienceTitle}
	items={content.experienceItems}
/>

<Certifications
	title={content.certificationsTitle}
	items={content.certificationItems}
/>

<CompetitionsSection
	title={content.competitionsTitle}
	categories={content.competitionCategories}
/>

<PresentationsSection
	title={content.presentationsTitle}
	categories={content.presentationCategories}
/>

<CommunityConferenceSection
	title={content.communityConferenceTitle}
	items={content.communityConferenceItems}
/>

<Footer title={content.title} quickLinks={content.quickLinks} />

<style>
	.page-actions {
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	@media (max-width: 520px) {
		.page-actions {
			flex-wrap: wrap;
			row-gap: 0.85rem;
		}
	}
</style>
