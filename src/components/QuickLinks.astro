---
import type { QuickLink } from "../i18n/content";

type Props = {
	links: readonly QuickLink[];
};

const { links } = Astro.props;
---

<nav class="quick-links" aria-label="Quick links">
	{links.map((link) => (
		<a href={link.href}>{link.label}</a>
	))}
</nav>

<style>
	.quick-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem 1rem;
		margin-top: 1.15rem;
	}

	.quick-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 5.5rem;
		padding: 0.7rem 0.9rem;
		border: 1px solid var(--line);
		background: transparent;
		color: var(--muted);
		text-decoration: none;
		font-size: 0.92rem;
		line-height: 1;
		text-align: center;
		transition:
			color var(--theme-duration, 0.32s) var(--ease),
			border-color var(--theme-duration, 0.32s) var(--ease),
			transform 0.2s ease;
	}

	.quick-links a:hover {
		color: var(--icon-hover);
		border-color: var(--icon-hover);
		transform: scale(1.05);
	}
</style>
