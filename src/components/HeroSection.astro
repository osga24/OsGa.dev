---
import bannerDark from "../assets/bannerDark.jpg";
import bannerLight from "../assets/bannerLight.jpg";
import ProfileInfo from "./ProfileInfo.astro";
import QuickLinks from "./QuickLinks.astro";
import SocialLinks from "./SocialLinks.astro";
import type { InfoSection, QuickLink, SocialLink } from "../i18n/content";

type Props = {
	title: string;
	tagline: string;
	intro: string;
	socialLinks: readonly SocialLink[];
	infoSections: readonly InfoSection[];
	quickLinks: readonly QuickLink[];
};

const { title, tagline, intro, socialLinks, infoSections, quickLinks } = Astro.props;
---

<section>
	<div class="banner-frame reveal-content" aria-hidden="true">
		<img class="banner-image banner-image-light" src={bannerLight.src} alt="" />
		<img class="banner-image banner-image-dark" src={bannerDark.src} alt="" />
	</div>
	<h1 class="wordmark" id="wordmark">{title}</h1>
	<div class="wordmark-spacer" aria-hidden="true"></div>
	<div class="reveal-content">
		<p class="tagline">{tagline}</p>
		<SocialLinks links={socialLinks} />
		<p class="lead">{intro}</p>
		<ProfileInfo sections={infoSections} />
		<QuickLinks links={quickLinks} />
	</div>
</section>

<style>
	section {
		width: 100%;
	}

	.banner-frame {
		display: grid;
		width: 100%;
		margin: 0 0 1.5rem;
	}

	.banner-image {
		grid-area: 1 / 1;
		display: block;
		width: 100%;
		height: auto;
		transition: opacity var(--theme-duration, 0.32s) var(--ease);
	}

	.banner-image-light {
		opacity: 1;
	}

	.banner-image-dark {
		opacity: 0;
	}

	:global(:root[data-theme="light"] .banner-image-light),
	:global(:root:not([data-theme]) .banner-image-light) {
		opacity: 1;
	}

	:global(:root[data-theme="light"] .banner-image-dark),
	:global(:root:not([data-theme]) .banner-image-dark) {
		opacity: 0;
	}

	:global(:root[data-theme="dark"] .banner-image-light) {
		opacity: 0;
	}

	:global(:root[data-theme="dark"] .banner-image-dark) {
		opacity: 1;
	}

	.tagline {
		margin: 0.35rem 0 0;
		font-size: 1rem;
		line-height: 1.4;
		color: var(--muted);
	}

	.reveal-content {
		width: 100%;
	}

	@media (max-width: 720px) {
		.banner-frame {
			margin-bottom: 1.15rem;
		}
	}

	@media (max-width: 520px) {
		.banner-frame {
			margin-bottom: 1rem;
		}
	}
</style>
