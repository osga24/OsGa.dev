---
import type { ExperienceItem } from "../i18n/content";

type Props = {
	eyebrow: string;
	title: string;
	intro: string;
	items: readonly ExperienceItem[];
};

const { eyebrow, title, intro, items } = Astro.props;
---

<section class="experience reveal-content">
	<header class="experience-header">
		<p class="eyebrow">{eyebrow}</p>
		<h2 class="section-title">{title}</h2>
		<p class="lead">{intro}</p>
	</header>

	<div class="experience-list">
		{items.map((item) => (
			<article class="experience-card">
				<div class="experience-meta">
					<p class="period">{item.period}</p>
					<h3>{item.role}</h3>
					<p class="company">{item.company}</p>
				</div>
				<div class="experience-body">
					<p>{item.summary}</p>
					<ul>
						{item.highlights.map((highlight) => <li>{highlight}</li>)}
					</ul>
				</div>
			</article>
		))}
	</div>
</section>

<style>
	.experience {
		width: 100%;
	}

	.experience-header {
		margin-bottom: 2rem;
	}

	.eyebrow {
		margin: 0 0 0.4rem;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.section-title {
		margin: 0;
		font-size: clamp(2rem, 6vw, 3.5rem);
		line-height: 0.95;
		letter-spacing: -0.05em;
	}

	.experience-list {
		display: grid;
		gap: 1rem;
	}

	.experience-card {
		display: grid;
		gap: 1rem;
		padding: 1.1rem 0 1.2rem;
		border-top: 1px solid var(--line);
	}

	.period,
	.company {
		margin: 0;
		color: var(--muted);
	}

	.experience-card h3 {
		margin: 0.15rem 0;
		font-size: 1.1rem;
	}

	.experience-body p {
		margin: 0;
		line-height: 1.6;
	}

	ul {
		margin: 0.75rem 0 0;
		padding-left: 1.1rem;
		color: var(--muted);
	}

	li + li {
		margin-top: 0.4rem;
	}

	@media (min-width: 720px) {
		.experience-card {
			grid-template-columns: 11rem 1fr;
			align-items: start;
		}
	}
</style>
