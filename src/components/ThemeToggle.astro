---
type Props = {
	lightLabel: string;
	darkLabel: string;
};

const { lightLabel, darkLabel } = Astro.props;
---

<button
	type="button"
	class="theme-toggle reveal-content"
	data-theme-toggle
	data-light-label={lightLabel}
	data-dark-label={darkLabel}
	aria-label="Toggle theme"
>
	<span class="theme-icon theme-icon-sun" aria-hidden="true">
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
			<circle cx="12" cy="12" r="4" />
			<path d="M12 2.5v2.2M12 19.3v2.2M21.5 12h-2.2M4.7 12H2.5M18.7 5.3l-1.5 1.5M6.8 17.2l-1.5 1.5M18.7 18.7l-1.5-1.5M6.8 6.8L5.3 5.3" />
		</svg>
	</span>
	<span class="theme-icon theme-icon-moon" aria-hidden="true">
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
			<path d="M20 14.2A7.8 7.8 0 0 1 9.8 4 8.8 8.8 0 1 0 20 14.2Z" />
		</svg>
	</span>
	<span class="sr-only" data-theme-toggle-label>{darkLabel}</span>
</button>

<script>
	const root = document.documentElement;
	const button = document.querySelector("[data-theme-toggle]");
	const label = button?.querySelector("[data-theme-toggle-label]");

	const updateThemeLabel = () => {
		if (!(button instanceof HTMLButtonElement) || !(label instanceof HTMLElement)) {
			return;
		}

		const theme = root.dataset.theme === "dark" ? "dark" : "light";
		const nextLabel =
			theme === "dark"
				? button.dataset.lightLabel ?? "Light"
				: button.dataset.darkLabel ?? "Dark";
		label.textContent = nextLabel;
		button.setAttribute("aria-label", nextLabel);
	};

	if (button instanceof HTMLButtonElement) {
		updateThemeLabel();

		button.addEventListener("click", () => {
			const nextTheme = root.dataset.theme === "dark" ? "light" : "dark";
			root.dataset.theme = nextTheme;

			try {
				window.localStorage.setItem("theme-preference", nextTheme);
			} catch {}

			updateThemeLabel();
		});
	}
</script>

<style>
	.theme-toggle {
		position: relative;
		appearance: none;
		border: 1px solid var(--line);
		background: transparent;
		color: var(--muted);
		border-radius: 999px;
		width: 2.5rem;
		height: 2.5rem;
		padding: 0;
		cursor: pointer;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		transition:
			border-color 0.2s ease,
			color 0.2s ease,
			background-color 0.2s ease;
	}

	.theme-toggle:hover {
		color: var(--icon-hover);
		border-color: var(--icon-hover);
	}

	.theme-icon {
		position: absolute;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		transition:
			opacity 0.2s ease,
			transform 0.2s ease;
	}

	.theme-icon svg {
		width: 1rem;
		height: 1rem;
		display: block;
	}

	:global(:root[data-theme="light"] .theme-icon-sun),
	:global(:root:not([data-theme]) .theme-icon-sun) {
		opacity: 1;
		transform: scale(1);
	}

	:global(:root[data-theme="light"] .theme-icon-moon),
	:global(:root:not([data-theme]) .theme-icon-moon) {
		opacity: 0;
		transform: scale(0.75);
	}

	:global(:root[data-theme="dark"] .theme-icon-sun) {
		opacity: 0;
		transform: scale(0.75);
	}

	:global(:root[data-theme="dark"] .theme-icon-moon) {
		opacity: 1;
		transform: scale(1);
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
</style>
